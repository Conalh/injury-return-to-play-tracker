# Shared runtime
RETURN_PLAY_ENV=local
RETURN_PLAY_SERVICE_NAME=return-play-api

# Backend API
RETURN_PLAY_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/return_play
RETURN_PLAY_AUTH_MODE=dev_headers
RETURN_PLAY_AUTH_SECRET=
RETURN_PLAY_ERROR_TRACKING_DSN=
RETURN_PLAY_CORS_ORIGINS=http://127.0.0.1:3217,http://localhost:3217
RETURN_PLAY_MAX_REQUEST_BYTES=1048576
RETURN_PLAY_AUTH_RATE_LIMIT_PER_MINUTE=20
RETURN_PLAY_SHARE_RATE_LIMIT_PER_MINUTE=120

# Optional local-only login provider. Leave disabled outside local testing.
RETURN_PLAY_LOCAL_AUTH_ENABLED=0
RETURN_PLAY_LOCAL_AUTH_EMAIL=
RETURN_PLAY_LOCAL_AUTH_PASSWORD=
RETURN_PLAY_LOCAL_AUTH_ACTOR_ID=clinician_demo
RETURN_PLAY_LOCAL_AUTH_ROLE=clinician
RETURN_PLAY_LOCAL_AUTH_ORGANIZATION_ID=org_demo

# Frontend web app
RETURN_PLAY_DATA_MODE=demo
RETURN_PLAY_API_BASE_URL=http://127.0.0.1:8000
RETURN_PLAY_API_TOKEN=
RETURN_PLAY_ACTOR_ID=clinician_demo
RETURN_PLAY_ACTOR_ROLE=clinician
RETURN_PLAY_ORGANIZATION_ID=org_demo
